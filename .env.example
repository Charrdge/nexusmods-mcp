# Скопируй в .env (файл .env в репозитории игнорируется git).
# Ключ: https://www.nexusmods.com/users/myaccount?tab=api
NEXUSMODS_API_KEY=your_key_here

# NEXUSMODS_APPLICATION_NAME=nexusmods-mcp-local
# NEXUSMODS_APPLICATION_VERSION=0.1.0
# NEXUSMODS_PROTOCOL_VERSION=1.5.2
# NEXUSMODS_REST_BASE=https://api.nexusmods.com/v1
# NEXUSMODS_GRAPHQL_URL=https://api.nexusmods.com/v2/graphql

# Опционально: streamable HTTP вместо stdio (не выставляй порт в интернет без защиты)
# MCP_TRANSPORT=http
# MCP_HTTP_ADDR=0.0.0.0:8080
